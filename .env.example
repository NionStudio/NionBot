# === Discord ===
# Token del bot (Discord Developer Portal → tu app → Bot → Reset Token)
DISCORD_TOKEN=
# Application ID / Client ID (Discord Developer Portal → General Information)
DISCORD_APP_ID=
# Client secret (OAuth2 — aún no usado por el bot)
DISCORD_CLIENT_SECRET=

# === Postgres (usado por Docker Compose y por Prisma) ===
POSTGRES_USER=nion
POSTGRES_PASSWORD=nion_dev_password
POSTGRES_DB=nion_studio
POSTGRES_PORT=5432

# URL de conexión que usa Prisma (coincide con las credenciales de arriba)
DATABASE_URL="postgresql://nion:nion_dev_password@localhost:5432/nion_studio?schema=public"

# === Redis (Docker Compose + BullMQ) ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === App ===
# development | production
NODE_ENV=development
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# === Visor de transcripciones (app en Vercel, carpeta web-transcript/) ===
# URL base de la app desplegada en Vercel.
TRANSCRIPT_APP_URL=
# Secreto HMAC compartido con la app (mismo valor en la env var de Vercel).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRANSCRIPT_SECRET=
